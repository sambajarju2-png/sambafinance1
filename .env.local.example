# PayWatch Environment Variables
# Copy to .env.local and fill in values

# ── Supabase ──
# Found at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # Server-only! Never expose client-side

# ── Anthropic (Claude Haiku) ──
# Found at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Google OAuth2 (Phase 3 — Gmail integration) ──
# Found at: console.cloud.google.com → Credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── NextAuth (Phase 3) ──
# NEXTAUTH_SECRET=                 # Run: openssl rand -base64 32
# NEXTAUTH_URL=                    # Your Vercel URL, e.g. https://sambafinance.vercel.app

# ── Token Encryption (Phase 3) ──
# ENCRYPTION_KEY=                  # Run: openssl rand -base64 32
