# PayWatch Environment Variables
# Copy to .env.local and fill in values

# ── Supabase ──
# Found at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # Server-only! The one that starts with eyJ... (NOT sb_publishable_)

# ── Anthropic (Claude Haiku) ──
# Found at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Google OAuth2 (Gmail connection) ──
# Found at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Token Encryption ──
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
